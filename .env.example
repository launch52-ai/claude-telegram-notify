# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your-chat-id-here

# Label for this machine (e.g. "MacBook Pro", "Mac Mini", "Work Mac")
# Falls back to system hostname if not set
MACHINE_NAME=

# MuxPod deep link ID (must match the Deep Link ID in MuxPod's connection settings)
# Leave empty to disable MuxPod links in notifications
MUXPOD_DEEP_LINK_ID=
